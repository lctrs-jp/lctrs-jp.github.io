    (cnfg P1 P2 P3 P4 P5 P6 P7 P8 P9 (p wrtr20 0) (sem S D T) X 0) /\ (band (bnot (mequals T (mplus D 2))) (mequals D2 (mplus D 2))) => (cnfg P1 P2 P3 P4 P5 P6 P7 P8 P9 (p wrtr18 0) (sem S D2 T) X 1),
    (cnfg P1 P2 P3 P4 P5 P6 P7 P8 P9 (p wrtr20 0) (sem S D T) X 0) /\ (band (mequals T (mplus D 2)) (mequals S1 (mplus S 1))) => (cnfg P1 P2 P3 P4 P5 P6 P7 P8 P9 (p wrtr18 0) (sem S1 D T) X 0),
