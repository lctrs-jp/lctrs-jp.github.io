sorts Thread, Config, State;

signature
    config : Thread Thread Thread Thread Thread Int Int  -> Config,
    thread : State  -> Thread,
    none :  -> Thread,
    main :  -> State,
    main0 :  -> State,
    main1 :  -> State,
    main2 :  -> State,
    main3 :  -> State,
    main4 :  -> State,
    main5 :  -> State,
    main6 :  -> State,
    main7 :  -> State,
    return0 :  -> State,
    setThread :  -> State,
    setThread1 :  -> State,
    setThread2 :  -> State,
    checkThread :  -> State,
    success :  -> Config,
    error :  -> Config,
    assert0 :  -> Config;

variables
    Thrd1 : Thread, Thrd2 : Thread, Thrd3 : Thread, A : Int, B : Int, S : State, Thrd0 : Thread, Thrd : Thread, A1 : Int, B1 : Int;

constrained-rewrite-system main
    (config (thread main) none Thrd1 Thrd2 Thrd3 A B) => (config (thread main0) (thread setThread) Thrd1 Thrd2 Thrd3 A B),
    (config (thread main) (thread S) Thrd1 Thrd2 Thrd3 A B) => error,
    (config (thread main0) Thrd0 none Thrd2 Thrd3 A B) => (config (thread main1) Thrd0 (thread setThread) Thrd2 Thrd3 A B),
    (config (thread main0) Thrd0 (thread S) Thrd2 Thrd3 A B) => error,
    (config (thread main1) Thrd0 Thrd1 none Thrd3 A B) => (config (thread main2) Thrd0 Thrd1 (thread setThread) Thrd3 A B),
    (config (thread main1) Thrd0 Thrd1 (thread S) Thrd3 A B) => error,
    (config (thread main2) Thrd0 Thrd1 Thrd2 none A B) => (config (thread main3) Thrd0 Thrd1 Thrd2 (thread checkThread) A B),
    (config (thread main2) Thrd0 Thrd1 Thrd2 (thread S) A B) => error,
    (config (thread main3) (thread return0) Thrd1 Thrd2 Thrd3 A B) => (config (thread main4) none Thrd1 Thrd2 Thrd3 A B),
    (config (thread main4) Thrd0 (thread return0) Thrd2 Thrd3 A B) => (config (thread main5) Thrd0 none Thrd2 Thrd3 A B),
    (config (thread main5) Thrd0 Thrd1 (thread return0) Thrd3 A B) => (config (thread main6) Thrd0 Thrd1 none Thrd3 A B),
    (config (thread main6) Thrd0 Thrd1 Thrd2 (thread return0) A B) => (config (thread main7) Thrd0 Thrd1 Thrd2 none A B),
    (config (thread main7) Thrd0 Thrd1 Thrd2 Thrd3 A B) => (config (thread return0) Thrd0 Thrd1 Thrd2 Thrd3 A B),
    (config Thrd (thread setThread) Thrd1 Thrd2 Thrd3 A B) /\ (mequals A1 1) => (config Thrd (thread setThread1) Thrd1 Thrd2 Thrd3 A1 B),
    (config Thrd (thread setThread1) Thrd1 Thrd2 Thrd3 A B) /\ (mequals B1 -1) => (config Thrd (thread setThread2) Thrd1 Thrd2 Thrd3 A B1),
    (config Thrd (thread setThread2) Thrd1 Thrd2 Thrd3 A B) => (config Thrd (thread return0) Thrd1 Thrd2 Thrd3 A B),
    (config Thrd Thrd0 (thread setThread) Thrd2 Thrd3 A B) /\ (mequals A1 1) => (config Thrd Thrd0 (thread setThread1) Thrd2 Thrd3 A1 B),
    (config Thrd Thrd0 (thread setThread1) Thrd2 Thrd3 A B) /\ (mequals B1 -1) => (config Thrd Thrd0 (thread setThread2) Thrd2 Thrd3 A B1),
    (config Thrd Thrd0 (thread setThread2) Thrd2 Thrd3 A B) => (config Thrd Thrd0 (thread return0) Thrd2 Thrd3 A B),
    (config Thrd Thrd0 Thrd1 (thread setThread) Thrd3 A B) /\ (mequals A1 1) => (config Thrd Thrd0 Thrd1 (thread setThread1) Thrd3 A1 B),
    (config Thrd Thrd0 Thrd1 (thread setThread1) Thrd3 A B) /\ (mequals B1 -1) => (config Thrd Thrd0 Thrd1 (thread setThread2) Thrd3 A B1),
    (config Thrd Thrd0 Thrd1 (thread setThread2) Thrd3 A B) => (config Thrd Thrd0 Thrd1 (thread return0) Thrd3 A B),
    (config Thrd Thrd0 Thrd1 Thrd2 (thread checkThread) A B) /\ (bnot (bor (band (mequals A 0) (mequals B 0)) (band (mequals A 1) (mequals B -1)))) => assert0,
    (config Thrd Thrd0 Thrd1 Thrd2 (thread checkThread) A B) /\ (bor (band (mequals A 0) (mequals B 0)) (band (mequals A 1) (mequals B -1))) => (config Thrd Thrd0 Thrd1 Thrd2 (thread return0) A B),
    (config Thrd Thrd0 Thrd1 Thrd2 Thrd3 A B) => success;

rewrite-system apr
    (config (thread main) none none none none 0 0) => success;

prove [10,10] in main : apr;
